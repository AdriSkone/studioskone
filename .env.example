# Copiez ce fichier en .env.local et remplissez les valeurs.
# .env.local est ignoré par git (via *.local dans .gitignore).
#
# En production, ces variables sont définies dans le dashboard Vercel
# (Project Settings → Environment Variables).

# ─────────────────────────────────────────────────────────────────────────────
# FRONT — exposé au navigateur (toutes les VITE_* sont injectées dans le bundle public).
# Ne JAMAIS y mettre de secret.
# ─────────────────────────────────────────────────────────────────────────────

# Umami : URL du script de tracking et identifiant du site (publics par design).
VITE_UMAMI_SCRIPT_URL=https://cloud.umami.is
VITE_UMAMI_WEBSITE_ID=

# ─────────────────────────────────────────────────────────────────────────────
# SERVEUR — Vercel Functions uniquement, jamais exposé au front.
# Définies dans Vercel (Production + Preview ; Development pour les non-Sensitive).
# ─────────────────────────────────────────────────────────────────────────────

# URL de base pour la génération des magic links — Production uniquement.
# En Preview, le code utilise automatiquement VERCEL_URL.
BASE_URL=https://studioskone.com

# Email admin destinataire des magic links.
ADMIN_EMAIL=

# Secret HMAC pour signer les cookies de session (≥ 32 caractères crypto-aléatoires).
# Générer avec : openssl rand -hex 32
SESSION_SECRET=

# Resend — envoi des magic links.
RESEND_API_KEY=
RESEND_FROM=Studio Skøne <noreply@mail.studioskone.com>

# Umami — accès admin à l'API stats (token serveur, sans préfixe VITE_).
UMAMI_API_TOKEN=
# Optionnel — surchargeable si vous changez de provider Umami.
VITE_UMAMI_API_URL=https://api.umami.is

# Vercel KV (Upstash Redis) — sessions, tokens magic link, rate-limit.
# Auto-injectées par l'intégration Upstash. Ne pas remplir à la main.
KV_REST_API_URL=
KV_REST_API_TOKEN=
