# Copiez ce fichier en .env.local et remplissez les valeurs
# .env.local est ignoré par git (via *.local dans .gitignore)

# ── Tracking script (injecté sur le site public) ─────────────────────────────
# Umami Cloud : https://cloud.umami.is
# Self-hosted : https://umami.votre-domaine.com
VITE_UMAMI_SCRIPT_URL=https://cloud.umami.is

# ── API (utilisée par la page admin) ─────────────────────────────────────────
# Umami Cloud : https://api.umami.is
# Self-hosted : https://umami.votre-domaine.com
VITE_UMAMI_API_URL=https://api.umami.is

# Website ID → Umami dashboard > Settings > Websites
VITE_UMAMI_WEBSITE_ID=

# API Token  → Umami dashboard > Settings > API Keys
VITE_UMAMI_API_TOKEN=

# ── Page admin ────────────────────────────────────────────────────────────────
VITE_ADMIN_PASSWORD=
